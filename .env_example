GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=<secret>
GITHUB_PRIVATE_KEY_PATH=<file>.pem
GITHUB_BOT_NAME=<name>
# Global LLM provider for analysts: local|anthropic|gemini|openai|mlx
TYPE_AGENTS=local
# Model name per analyst — provider-agnostic, interpreted by the chosen provider.
# local:     qwen2.5:7b / qwen2.5:3b
# anthropic: claude-sonnet-4-5 / claude-haiku-4-5
# gemini:    gemini-2.0-flash / gemini-2.0-flash-lite
# openai:    gpt-4o / gpt-4o-mini
# mlx:       HF id served by mlx_lm.server, e.g. mlx-community/Qwen3.5-9B-MLX-4bit
MODEL_SECURITY=qwen2.5:7b
MODEL_STYLE=qwen2.5:3b
# Cloud API keys — read only when TYPE_AGENTS matches.
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# MLX provider — runs on Apple Silicon via the mlx_lm.server OpenAI-compatible
# endpoint. Start the server in a separate terminal before launching uvicorn:
#   mlx_lm.server --model mlx-community/Qwen3.5-9B-MLX-4bit --port 8080
MLX_BASE_URL=http://localhost:8080/v1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_REQUEST_TIMEOUT=300
# Ollama num_ctx defaults to 2048 and silently truncates anything bigger.
# Our typical input (diff + rules + system prompt) runs ~8-12k tokens, so
# raise the window per model. RAM cost at Q4_K_M is roughly +2 bytes/token
# /layer for KV cache — 16k ctx on qwen2.5:7b adds ~2-3GB over the base
# ~4.5GB. Tune down if running on 8GB machines.
OLLAMA_NUM_CTX_SECURITY=16384
OLLAMA_NUM_CTX_STYLE=8192
# How long Ollama keeps the model resident in RAM after a request.
# Default is 5m; set "30m" / "1h" / "-1" (forever) to avoid cold-start
# between PRs. Passed per-request, no systemd/launchd plumbing required.
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT_ANALYST=4096
# How the diff is presented to analysts.
# `raw`      — unified-diff (what git produces)
# `markdown` — per-file markdown with explicit line numbers, '+' lines only.
#              Cuts 30-50% prefill tokens; removes @@-hunk-math error class.
DIFF_FORMAT=raw
# Adaptive chunking — split oversized diffs across multiple LLM calls.
# Required: DIFF_FORMAT=markdown (chunking splits along ## file headers).
#
# Char budget per single LLM call. With num_ctx=16384 and ~10k-char system
# prompt + 4k output tokens, ~40000 diff-chars (~10k tokens) is safe.
# Bump to ~100000 if num_ctx is raised to 32k.
MAX_DIFF_CHARS_PER_CALL=40000
# Cap on number of LLM calls one analyst may make per review:
#   -1   unlimited (full coverage, default)
#    0   disable chunking — always one call (legacy behaviour)
#   >0   process at most N chunks; remaining ones logged + dumped
#        to <agent>-skipped-chunks.txt for visibility (not reviewed).
MAX_CHUNKS_PER_AGENT=-1
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_RULES_PER_CATEGORY=4
MILVUS_SCORE_THRESHOLD=1.5
CHECKPOINT_SQLITE_PATH=.data/reviewer_checkpoints.sqlite
# CHECKPOINT_POSTGRES_DSN=postgresql+asyncpg://user:pass@localhost:5432/dbname
MAX_CRITIC_ITERATIONS=3
ENABLED_AGENTS=security,style
LOG_LEVEL=INFO
# Hybrid retrieval (Plan A)
BM25_ENABLED=true
DENSE_OVERFETCH_MULTIPLIER=3
USE_RERANKER=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Deterministic linter pass (ruff) before analysts
LINTER_ENABLED=true
LINTER_MAX_FINDINGS_PER_FILE=3
LINTER_MAX_FINDINGS_TOTAL=10
# HITL: if true, skip the terminal prompt and auto-approve before summarizer.
# If false, prompt [a]pprove/[r]etry in the terminal where uvicorn is running.
HITL_AUTO_APPROVE=false
# Per-PR review transcripts are written here as markdown.
OUTPUT_DIR=output
