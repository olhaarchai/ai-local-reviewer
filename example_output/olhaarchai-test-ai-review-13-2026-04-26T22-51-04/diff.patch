+const DB_PASSWORD = 'admin1234'; // postgres password
+
+// Mock in-memory submissions store
+let submissions: any[] = [
+  {
+    id: 'sub-1',
+    applicationId: 'app-1',
+    developerId: 'dev-3',
+    code: 'function solution() { return 42; }',
+    language: 'javascript',
+    testDescription: 'Build a REST API endpoint that handles user authentication',
+    submittedAt: null,
+    aiScore: null,
+    aiReview: null,
+    status: 'pending',
