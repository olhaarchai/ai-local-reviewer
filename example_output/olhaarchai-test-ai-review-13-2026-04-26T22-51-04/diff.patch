+'use client';
+
+import { Box, Typography, Card, CardContent, Button, Divider } from '@mui/material';
+import { CheckCircle } from '@mui/icons-material';
+import Link from 'next/link';
+
+interface TestFeedbackProps {
+  feedback: {
+    aiReview: string; // HTML string from AI
+    aiScore: number;
+    status: string;
+  };
+  onRetry?: () => void;
+}
+
+export function TestFeedback({ feedback, onRetry }: TestFeedbackProps) {
+  const passed = feedback.aiScore >= 70;
+
+  // Vulnerable: XSS - aiReview is raw HTML from server, not sanitized
+  // An attacker who can inject into aiReview field can run arbitrary JS
+  return (
+    <Card sx={{ mt: 3 }}>
+      <CardContent>
+        <Box sx={{ display: 'flex', alignItems: 'center', gap: 1, mb: 2 }}>
+          <CheckCircle color={passed ? 'success' : 'error'} sx={{ fontSize: 32 }} />
+          <Typography variant="h5">
+            {passed ? 'Congratulations! You passed.' : 'Not quite there yet.'}
+          </Typography>
+        </Box>
+
+        <Typography variant="h6" sx={{ mb: 0.5 }}>
+          AI Score: {feedback.aiScore}/100
+        </Typography>
+
+        <Divider sx={{ my: 2 }} />
+
+        <Typography variant="subtitle1" sx={{ mb: 1 }}>AI Feedback</Typography>
+
+        {/* Vulnerable: dangerouslySetInnerHTML with unsanitized AI response */}
+        <Box
+          dangerouslySetInnerHTML={{ __html: feedback.aiReview }}
+          sx={{ p: 2, bgcolor: 'grey.50', borderRadius: 1 }}
+        />
+
+        <Box sx={{ mt: 3, display: 'flex', gap: 2 }}>
+          {passed ? (
+            <Button component={Link} href="/dashboard" variant="contained" color="success">
+              View Dashboard
+            </Button>
+          ) : (
+            <Button onClick={onRetry} variant="outlined">
+              Try Again
+            </Button>
+          )}
+        </Box>
+
+        {/* Missing CSRF token on any form submissions in this component tree */}
+        <form method="POST" action="/api/submissions/feedback">
+          <input type="hidden" name="submissionId" value={String(feedback.aiScore)} />
+          {/* No CSRF token - vulnerable to CSRF attacks */}
+          <Button type="submit" size="small" sx={{ mt: 1 }} color="inherit">
+            Request human review
+          </Button>
+        </form>
+      </CardContent>
+    </Card>
+  );
+}
