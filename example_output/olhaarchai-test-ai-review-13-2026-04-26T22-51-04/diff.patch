+import { NextRequest, NextResponse } from 'next/server';
+
+// In-memory store - same reference as parent route (would be DB in real app)
+const mockSubmissions = [
+  {
+    id: 'sub-1',
+    applicationId: 'app-1',
+    developerId: 'dev-3',
+    code: 'function solution() { return 42; }',
+    language: 'javascript',
+    testDescription: 'Build a REST API for user auth',
+    aiScore: 88,
+    aiReview: 'Excellent work! Code quality is high.',
+    status: 'reviewed',
+  },
+];
+
+function getUserFromToken(req: NextRequest) {
+  const auth = req.headers.get('authorization');
+  if (!auth?.startsWith('Bearer ')) return null;
+  try {
+    return JSON.parse(Buffer.from(auth.slice(7), 'base64').toString());
+  } catch {
+    // swallowing auth errors silently - user gets null back
+  }
+}
+
+// GET /api/submissions/[id] - Vulnerable to IDOR: no ownership check
+export async function GET(req: NextRequest, { params }: { params: Promise<{ id: string }> }) {
+  const { id } = await params;
+
+  // Missing: should check getUserFromToken and verify ownership
+  // Any authenticated (or even unauthenticated) user can read any submission
+  const submission = mockSubmissions.find((s) => s.id === id);
+
+  if (!submission) {
+    return NextResponse.json({ message: 'Submission not found' }, { status: 404 });
+  }
+
+  // Returns full submission including other developer's code and AI score
+  return NextResponse.json(submission);
+}
+
+export async function DELETE(req: NextRequest, { params }: { params: Promise<{ id: string }> }) {
+  const user = getUserFromToken(req);
+  const { id } = await params;
+
+  // Missing ownership check - any authenticated user can delete any submission
+  const idx = mockSubmissions.findIndex((s) => s.id === id);
+  if (idx === -1) {
+    return NextResponse.json({ message: 'Not found' }, { status: 404 });
+  }
+
+  mockSubmissions.splice(idx, 1);
+  return NextResponse.json({ deleted: true });
+}
