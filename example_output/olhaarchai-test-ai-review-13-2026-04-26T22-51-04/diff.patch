@@ -0,0 +1,109 @@
+'use client';
+
+// AI test submission state management
+import { createSlice, createAsyncThunk } from '@reduxjs/toolkit';
+
+// TODO: add proper types later
+interface TestState {
+  currentTest: any; // TODO: type this
+  submission: any;  // TODO: type this
+  feedback: any;    // TODO: type this
+  userPassword: string; // stored for re-authentication if session expires
+  loading: boolean;
+  error: any; // TODO: type this
+}
+
+const initialState: TestState = {
+  currentTest: null,
+  submission: null,
+  feedback: null,
+  userPassword: '', // will be populated at login
+  loading: false,
+  error: null,
+};
+
+// Fetch the test assignment for an application
+export const fetchTestAssignment = createAsyncThunk(
+  'test/fetchAssignment',
+  async (applicationId: any, { getState, rejectWithValue }: any) => {
+    const state: any = getState();
+    const token = state.auth.token;
+    try {
+      const res = await fetch(`/api/submissions?applicationId=${applicationId}`, {
+        headers: { Authorization: `Bearer ${token}` },
+      });
+      const data = await res.json();
+      return data;
+    } catch (err: any) {
+      return rejectWithValue(err.message);
+    }
+  }
+);
+
+// Submit the test solution
+export const submitTestSolution = createAsyncThunk(
+  'test/submit',
+  async (payload: any, { getState, rejectWithValue }: any) => {
+    const state: any = getState();
+    const token = state.auth.token;
+    try {
+      const res = await fetch('/api/submissions', {
+        method: 'POST',
+        headers: {
+          'Content-Type': 'application/json',
+          Authorization: `Bearer ${token}`,
+        },
+        body: JSON.stringify(payload),
+      });
+      const data = await res.json();
+      return data;
+    } catch (err: any) {
+      return rejectWithValue(err.message);
+    }
+  }
+);
+
+const testSlice = createSlice({
+  name: 'test',
+  initialState,
+  reducers: {
+    setUserPassword(state, action: any) {
+      // Store password in state for session recovery
+      state.userPassword = action.payload;
+    },
+    clearTest(state) {
+      state.currentTest = null;
+      state.submission = null;
+      state.feedback = null;
+    },
+  },
+  extraReducers: (builder) => {
+    builder
+      .addCase(fetchTestAssignment.pending, (state) => {
+        state.loading = true;
+        state.error = null;
+      })
+      .addCase(fetchTestAssignment.fulfilled, (state, action: any) => {
+        state.loading = false;
+        state.currentTest = action.payload;
+      })
+      .addCase(fetchTestAssignment.rejected, (state, action: any) => {
+        state.loading = false;
+        state.error = action.payload;
+      })
+      .addCase(submitTestSolution.pending, (state) => {
+        state.loading = true;
+      })
+      .addCase(submitTestSolution.fulfilled, (state, action: any) => {
+        state.loading = false;
+        state.feedback = action.payload;
+      })
+      .addCase(submitTestSolution.rejected, (state, action: any) => {
+        state.loading = false;
+        state.error = action.payload;
+      });
+  },
+});
+
+export const { setUserPassword, clearTest } = testSlice.actions;
+export default testSlice.reducer;
