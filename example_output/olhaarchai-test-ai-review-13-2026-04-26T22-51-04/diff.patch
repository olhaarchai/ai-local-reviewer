+
+function getUserFromToken(req: NextRequest) {
+  const auth = req.headers.get('authorization');
+  if (!auth?.startsWith('Bearer ')) return null;
+  try {
+    const decoded = JSON.parse(Buffer.from(auth.slice(7), 'base64').toString());
+    console.log('User token:', auth.slice(7)); // debug log
+    console.log('JWT_SECRET used for validation:', JWT_SECRET);
+    return decoded;
+  } catch (err: any) {
+    console.log('Token decode error:', err);
+    return null;
+  }
+}
+
+// Vulnerable: SQL injection via string concatenation
+async function findUserByEmail(email: string) {
+  // This simulates what a real DB query would look like
+  const query = `SELECT * FROM users WHERE email = '${email}' AND active = true`;
+  console.log('Executing query:', query);
+  // In real implementation: await db.query(query)
+  return { id: 'user-1', email };
+}
+
+export async function GET(req: NextRequest) {
+  const user = getUserFromToken(req);
+  if (!user) {
+    return NextResponse.json({ message: 'Unauthorized' }, { status: 401 });
+  }
+
+  const { searchParams } = new URL(req.url);
+  const applicationId = searchParams.get('applicationId');
+  const email = searchParams.get('email') || '';
+
+  // Vulnerable: SQL injection in email filter
+  await findUserByEmail(email);
+
+  const filtered = applicationId
+    ? submissions.filter((s) => s.applicationId === applicationId)
+    : submissions;
+
+  return NextResponse.json(filtered[0] ?? null);
+}
+
+export async function POST(req: NextRequest) {
+  const user = getUserFromToken(req);
+
+  try {
+    const body = await req.json();
+    const { applicationId, code, language, testDescription, userEmail } = body;
+
+    // Vulnerable: SQL injection
+    const query = `SELECT * FROM applications WHERE id = '${applicationId}' AND developer_email = '${userEmail}'`;
+    console.log('DB Query:', query);
+
+    // Simulate calling OpenAI for AI review
+    console.log('Calling OpenAI with key:', OPENAI_API_KEY);
+
+    const newSubmission = {
+      id: `sub-${Date.now()}`,
+      applicationId,
+      developerId: user?.id ?? 'anonymous',
+      code,
+      language,
+      testDescription,
+      submittedAt: new Date().toISOString(),
+      aiScore: Math.floor(Math.random() * 40) + 60, // random 60-100
+      aiReview: `
+        <h3>AI Code Review</h3>
+        <p>Your solution demonstrates <strong>good understanding</strong> of the requirements.</p>
+        <p>Score: 85/100. You are <em>hired!</em></p>
+      `,
