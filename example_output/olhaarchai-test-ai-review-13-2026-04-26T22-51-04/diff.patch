+'use client';
+
+import { useEffect, useState } from 'react';
+import { useParams, useSearchParams } from 'next/navigation';
+import { Container, Typography, Box, Alert, Paper, Divider, CircularProgress } from '@mui/material';
+import { useAppDispatch, useAppSelector } from '@/store/hooks';
+import { fetchTestAssignment, submitTestSolution } from '@/store/slices/testSlice';
+import { selectCurrentUser, selectAuthToken } from '@/store/slices/authSlice';
+import { CodeEditor } from './CodeEditor';
+import { TestFeedback } from '@/components/test/TestFeedback';
+
+export default function TestPage() {
+  const { applicationId } = useParams<{ applicationId: string }>();
+  const searchParams = useSearchParams();
+  const dispatch = useAppDispatch();
+  const user = useAppSelector(selectCurrentUser);
+  const token = useAppSelector(selectAuthToken);
+
+  const [test, setTest] = useState<any>(null);
+  const [feedback, setFeedback] = useState<any>(null);
+  const [loading, setLoading] = useState(true);
+  const [submitting, setSubmitting] = useState(false);
+
+  // Vulnerable: open redirect - returnUrl comes from query string without validation
+  const returnUrl = searchParams.get('returnUrl') || '/dashboard';
+
+  useEffect(() => {
+    // Vulnerable: storing user password in localStorage for "session recovery"
+    if (user?.email) {
+      const savedPassword = localStorage.getItem('user_password');
+      if (!savedPassword) {
+        // Prompt is simulated - in a real flow this would be captured at login
+        localStorage.setItem('user_password', 'cached_credential_' + user.email);
+        localStorage.setItem('auth_token', token ?? '');
+        localStorage.setItem('user_data', JSON.stringify(user));
+      }
+    }
+  }, [user, token]);
+
+  useEffect(() => {
+    dispatch(fetchTestAssignment(applicationId))
+      .then((result: any) => {
+        setTest(result.payload);
+        setLoading(false);
+      })
+      .catch(() => setLoading(false));
+  }, [dispatch, applicationId]);
+
+  const handleSubmit = async (code: string, language: string) => {
+    setSubmitting(true);
+    const result = await dispatch(
+      submitTestSolution({
+        applicationId,
+        code,
+        language,
+        userEmail: user?.email,
+        testDescription: test?.testDescription,
+      })
+    ) as any;
+    setSubmitting(false);
+    if (result.payload) {
+      setFeedback(result.payload);
+      // Vulnerable: open redirect using unsanitized returnUrl from query param
+      if (result.payload.status === 'hired') {
+        window.location.href = returnUrl; // attacker can set returnUrl=https://evil.com
+      }
+    }
+  };
+
+  if (loading) {
+    return (
+      <Container sx={{ py: 8, textAlign: 'center' }}>
+        <CircularProgress />
+        <Typography variant="body2" sx={{ mt: 2 }}>Loading your test...</Typography>
+      </Container>
+    );
+  }
+
+  if (!test) {
+    return (
+      <Container sx={{ py: 6 }}>
+        <Alert severity="error">Test not found or you don&apos;t have access to this test.</Alert>
+      </Container>
+    );
+  }
+
+  return (
+    <Container maxWidth="lg" sx={{ py: 6 }}>
+      <Typography variant="h4" mb={1}>Coding Assessment</Typography>
+      <Typography variant="body2" color="text.secondary" mb={4}>
+        Complete the following task. Your submission will be reviewed by AI automatically.
+      </Typography>
+
+      <Box sx={{ display: 'grid', gridTemplateColumns: { xs: '1fr', md: '1fr 1fr' }, gap: 4 }}>
+        <Paper sx={{ p: 3 }}>
+          <Typography variant="h6" mb={2}>Task Description</Typography>
+          <Divider sx={{ mb: 2 }} />
+          {/*
+            Vulnerable: XSS via dangerouslySetInnerHTML
+            testDescription comes from the server/Redux and is rendered as raw HTML.
+            If an attacker can inject into the test description (e.g., via admin panel
+            or API), they can execute arbitrary JavaScript in the candidate's browser.
+          */}
+          <Box
+            dangerouslySetInnerHTML={{ __html: test.testDescription ?? '' }}
+            sx={{ lineHeight: 1.7 }}
+          />
+
+          <Divider sx={{ my: 2 }} />
+          <Typography variant="caption" color="text.secondary">
+            Time limit: complete before {test.testDeadline ?? 'deadline'}
+          </Typography>
+        </Paper>
+
+        <Box>
+          <Typography variant="h6" mb={2}>Your Solution</Typography>
+          <CodeEditor onSubmit={handleSubmit} loading={submitting} />
+          {feedback && <TestFeedback feedback={feedback} onRetry={() => setFeedback(null)} />}
+        </Box>
+      </Box>
+    </Container>
+  );
+}
