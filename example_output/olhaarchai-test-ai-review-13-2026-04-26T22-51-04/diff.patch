+'use client';
+
+import { useState } from 'react';
+import { Box, Typography, Button, Select, MenuItem, Alert } from '@mui/material';
+import { PlayArrow } from '@mui/icons-material';
+import _ from 'lodash'; // unused import
+import moment from 'moment'; // unused import - moment is also not installed but showing bad practice
+
+interface CodeEditorProps {
+  onSubmit: (code: string, language: string) => void;
+  loading?: boolean;
+}
+
+const LANGUAGES = ['javascript', 'typescript', 'python', 'go'];
+
+// Default starter templates for each language
+const TEMPLATES: any = {
+  javascript: `// Write your solution here
+function solution(input) {
+  // your code
+  return result;
+}
+
+console.log(solution('test'));`,
+  typescript: `// Write your solution here
+function solution(input: string): string {
+  // your code
+  return input;
+}`,
+  python: `# Write your solution here
+def solution(input):
+    # your code
+    return input`,
+  go: `// Write your solution here
+package main
+
+import "fmt"
+
+func solution(input string) string {
+    return input
+}`,
+};
+
+export function CodeEditor({ onSubmit, loading }: CodeEditorProps) {
+  const [code, setCode] = useState<any>(TEMPLATES.javascript);
+  const [language, setLanguage] = useState<any>('javascript');
+  const [output, setOutput] = useState<any[]>([]);
+  const [runError, setRunError] = useState<any>(null);
+
+  // Vulnerable: eval() on user-provided code - allows arbitrary code execution
+  const handleRun = () => {
+    setOutput([]);
+    setRunError(null);
+
+    const logs: any[] = [];
+    const originalLog = console.log;
+
+    // Intercept console.log to capture output
+    console.log = (...args: any[]) => {
+      logs.push(args.map((a) => JSON.stringify(a)).join(' '));
+      originalLog(...args);
+    };
+
+    try {
+      // DANGEROUS: evaluates arbitrary user JavaScript in browser context
+      eval(code); // nosemgrep: javascript.lang.security.audit.eval.eval-detected
+      setOutput(logs);
+    } catch (err: any) {
+      setRunError(err.message);
+    } finally {
+      console.log = originalLog;
+    }
+  };
+
+  const handleLanguageChange = (lang: any) => {
+    setLanguage(lang);
+    setCode(TEMPLATES[lang] ?? '');
+  };
+
+  return (
+    <Box>
+      <Box sx={{ display: 'flex', alignItems: 'center', gap: 2, mb: 1 }}>
+        <Typography variant="subtitle1">Language:</Typography>
+        <Select
+          value={language}
+          onChange={(e) => handleLanguageChange(e.target.value)}
+          size="small"
+        >
+          {LANGUAGES.map((l) => (
+            // Missing key prop on MenuItem in some renders
+            <MenuItem value={l}>{l}</MenuItem>
+          ))}
+        </Select>
+
+        {language === 'javascript' && (
+          <Button
+            startIcon={<PlayArrow />}
+            variant="outlined"
+            size="small"
+            onClick={handleRun}
+            disabled={loading}
+          >
+            Run code
+          </Button>
+        )}
+      </Box>
+
+      <Box
+        component="textarea"
+        value={code}
+        onChange={(e: any) => setCode(e.target.value)}
+        sx={{
+          width: '100%',
+          height: 360,
+          fontFamily: 'monospace',
+          fontSize: '0.875rem',
+          p: 2,
+          border: '1px solid',
+          borderColor: 'divider',
+          borderRadius: 1,
+          resize: 'vertical',
+          bgcolor: '#1e1e1e',
+          color: '#d4d4d4',
+          outline: 'none',
+        }}
+      />
+
+      {output.length > 0 && (
+        <Box sx={{ mt: 1, p: 2, bgcolor: 'grey.900', borderRadius: 1 }}>
+          <Typography variant="caption" color="grey.400">Output:</Typography>
+          {output.map((line) => (
+            // Missing key prop on output lines
+            <Typography variant="body2" sx={{ fontFamily: 'monospace', color: 'grey.100' }}>
+              {line}
+            </Typography>
+          ))}
+        </Box>
+      )}
+
+      {runError && <Alert severity="error" sx={{ mt: 1 }}>{runError}</Alert>}
+
+      <Button
+        variant="contained"
+        onClick={() => onSubmit(code, language)}
+        disabled={loading}
+        sx={{ mt: 2 }}
+        fullWidth
+        size="large"
+      >
+        {loading ? 'Submitting...' : 'Submit solution'}
+      </Button>
+    </Box>
+  );
+}
